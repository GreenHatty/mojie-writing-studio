# Local development only. Never commit a real value into .env files.
# Use exactly 32 random bytes, encoded as base64url, for LOCAL_DRAFT_KEK.
APP_ORIGIN=http://localhost:3000
NODE_ENV=development
OWNER_INITIALIZATION_KEY=replace-with-a-long-local-only-value
LOCAL_DRAFT_KEK=replace-with-a-32-byte-base64url-value
